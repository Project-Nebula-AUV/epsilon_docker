#!/usr/bin/env python3
"""
Refactored Gate task using reusable subtasks. Includes stabilization after alignment.
Vision processing is now handled by the Vision class passed from Submarine.
Now passes target_depth to context.
"""
import math
from typing import Tuple, List
import numpy as np

# --- USE STRING HINT 'Submarine' ---
from robosub.sub.tasks.task_base import Task, TaskStatus # Keep Task import
# ---
from robosub.sub.tasks.subtask_base import Subtask, SubtaskStatus
from robosub.sub.tasks.common_subtasks import (DiveToDepth, WaitForTargetVisible, AlignToObjectX, DriveStraight,
                                      Stabilize, DriveUntilTargetLost, StyleRollSubtask)

from robosub.sub.data_structures import SensorSuite, Vision, ThrusterCommands
from robosub.sub.utils import angle_diff

class GateTask(Task):
    """Navigates through the gate defined by two red poles at a target depth."""

    def __init__(self, target_depth: float = 1.0, style_roll_degrees: float = 0.0,
                 style_roll_timeout: float = 75.0):

        self.target_depth = target_depth # Store target depth

        # Commit to one side of the opening rather than splitting the gate
        # down the middle — an ambiguous center pass gives no signal for
        # which side to keep favoring through the slalom immediately after.
        # A fixed, off-center alignment target reliably lands the sub to one
        # side of the gate's true center: aiming right-of-center in frame
        # (fraction > 0.5) turns the sub's nose left of the gate, so it exits
        # on the gate's right; here we bias left-of-center in frame instead,
        # putting the sub through on the gate's right side.
        self.chosen_side = 'right'
        bias = 0.15
        target_x_fraction = 0.5 - bias if self.chosen_side == 'right' else 0.5 + bias

        align = dict(target_x_fraction=target_x_fraction,
                     tolerance_px=10,
                     yaw_gain=1.5,
                     yaw_rate_tolerance=0.05)

        self.subtasks = [
            DiveToDepth(),
            WaitForTargetVisible(target_type='gate'),
            AlignToObjectX(**align),
            Stabilize(duration=1.0, speed_threshold=0.1),
        ]
        if style_roll_degrees > 0:
            # Style points: barrel-roll in front of the gate, then hold a
            # deliberate stop there, re-align (the roll drifts the sub a
            # little), stop again, and only then drive through.
            # Timeout completes (not fails) so a roll the vehicle physically
            # can't finish never strands the mission.
            self.subtasks += [
                StyleRollSubtask(degrees=style_roll_degrees,
                                 timeout=style_roll_timeout),
                Stabilize(duration=3.0, speed_threshold=0.05),
                AlignToObjectX(**align),
                Stabilize(duration=3.0, speed_threshold=0.05),
            ]
        self.subtasks += [
            DriveUntilTargetLost(surge_power=0.6, target_type='gate'),
            DriveStraight(duration=4.0, surge_power=0.6),
            Stabilize(duration=1.0)
        ]

        super().__init__()
        self.reset()

    def reset(self, search_direction: int = 1):
        """Resets the task and adds target_depth to the context."""
        super().reset(search_direction)
        self.context['target_depth'] = self.target_depth

    # Execute method is inherited, uses 'Submarine' hint from base class